# ── PostgreSQL ───────────────────────────────────────────────
MKB_PG_HOST=localhost
MKB_PG_PORT=5432
MKB_PG_USER=mkb
MKB_PG_PASSWORD=mkb_dev
MKB_PG_DATABASE=mkb

# ── MinIO / S3 ──────────────────────────────────────────────
MKB_S3_ENDPOINT=http://localhost:9000
MKB_S3_ACCESS_KEY=minioadmin
MKB_S3_SECRET_KEY=minioadmin
MKB_S3_BUCKET_RAW=raw
MKB_S3_BUCKET_ARCHIVE=archive
MKB_S3_BUCKET_TEMP=temp

# ── LLM Extraction (LiteLLM + OpenAI-compatible API) ────────
# Model format examples:
#   openai/qwen-plus
#   openai/qwen-max
MKB_EXTRACTION_MODEL=openai/qwen-plus

# You can set OPENAI_API_KEY / OPENAI_API_BASE directly (recommended),
# or use the MKB_ prefixed aliases below.
OPENAI_API_KEY=
OPENAI_API_BASE=
# MKB_OPENAI_API_KEY=
# MKB_OPENAI_API_BASE=
